// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String      @id @default(cuid())
  username  String      @unique
  password  String
  isAdmin   Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  bookmarks Bookmark[]
  recents   RecentView[]
}

model Movie {
  id            String         @id @default(cuid())
  tmdbId        Int?           @unique
  title         String
  year          Int
  rating        Float          @default(0)
  duration      Int            @default(0)
  poster        String?
  backdrop      String?
  description   String         @default("")
  review        String?
  genres        String         @default("")
  quality4k     Boolean        @default(false)
  director      String?
  fileSize      String?
  quality       String?
  format        String?
  subtitle      String?
  imdbRating    Float?
  rtRating      Int?
  downloadLinks DownloadLink[]
  casts         Cast[]
  bookmarks     Bookmark[]
  recents       RecentView[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([tmdbId])
  @@index([genres])
}

model Series {
  id            String         @id @default(cuid())
  tmdbId        Int?           @unique
  title         String
  year          Int
  rating        Float          @default(0)
  poster        String?
  backdrop      String?
  description   String         @default("")
  genres        String         @default("")
  quality4k     Boolean        @default(false)
  seasons       Int            @default(1)
  totalEpisodes Int            @default(0)
  downloadLinks DownloadLink[]
  episodes      Episode[]
  casts         Cast[]
  bookmarks     Bookmark[]
  recents       RecentView[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([tmdbId])
  @@index([genres])
}

model Episode {
  id            String         @id @default(cuid())
  tmdbId        Int?           @unique
  seriesId      String
  series        Series         @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  season        Int
  episode       Int
  title         String
  duration      Int            @default(0)
  fileSize      String?
  quality       String?
  format        String?
  downloadLinks DownloadLink[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([seriesId])
}

model DownloadLink {
  id        String   @id @default(cuid())
  movieId   String?
  seriesId  String?
  episodeId String?
  quality   String
  url       String
  size      String?
  createdAt DateTime @default(now())

  movie   Movie?   @relation(fields: [movieId], references: [id], onDelete: Cascade)
  series  Series?  @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  episode Episode? @relation(fields: [episodeId], references: [id], onDelete: Cascade)
}

model Cast {
  id       String  @id @default(cuid())
  name     String
  photo    String?
  role     String?
  movieId  String?
  seriesId String?
  movie    Movie?  @relation(fields: [movieId], references: [id], onDelete: Cascade)
  series   Series? @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@index([movieId])
  @@index([seriesId])
}

model Genre {
  id        String   @id @default(cuid())
  name      String
  type      String
  createdAt DateTime @default(now())

  @@unique([name, type])
}

model Collection {
  id        String   @id @default(cuid())
  name      String
  type      String
  createdAt DateTime @default(now())

  @@unique([name, type])
}

model Tag {
  id        String   @id @default(cuid())
  name      String
  type      String
  createdAt DateTime @default(now())
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movieId   String?
  seriesId  String?
  movie     Movie?   @relation(fields: [movieId], references: [id], onDelete: Cascade)
  series    Series?  @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

model RecentView {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movieId   String?
  seriesId  String?
  movie     Movie?   @relation(fields: [movieId], references: [id], onDelete: Cascade)
  series    Series?  @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  viewedAt  DateTime @default(now())

  @@index([userId])
}
